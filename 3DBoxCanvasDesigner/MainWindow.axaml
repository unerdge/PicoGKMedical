<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="BoxCanvasDesigner.MainWindow"
        Title="3D盒型画布设计器"
        Width="900" Height="700"
        WindowStartupLocation="CenterScreen">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- 顶部标题 -->
        <TextBlock Grid.Row="0" Text="3D盒型画布设计器" FontSize="20" FontWeight="Bold" Margin="20,15,20,10"/>

        <!-- 主体TabControl -->
        <TabControl Grid.Row="1" Margin="10,0,10,10">

            <!-- Tab1: 智能推荐 -->
            <TabItem Header="智能推荐">
                <ScrollViewer>
                    <StackPanel Margin="15" Spacing="12">
                        <TextBlock Text="告诉我们你的产品" FontSize="16" FontWeight="SemiBold"/>

                        <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,10,0,0">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="产品名称:" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Name="ProductNameBox" Text="手机壳" Width="200" HorizontalAlignment="Left"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="尺寸 (cm):" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="5" Margin="0,8,0,0">
                                <TextBox Name="ProdLengthBox" Text="16" Width="60"/>
                                <TextBlock Text="x" VerticalAlignment="Center"/>
                                <TextBox Name="ProdWidthBox" Text="8" Width="60"/>
                                <TextBlock Text="x" VerticalAlignment="Center"/>
                                <TextBox Name="ProdHeightBox" Text="1.5" Width="60"/>
                            </StackPanel>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="重量 (kg):" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Name="ProdWeightBox" Text="0.05" Width="100" HorizontalAlignment="Left" Margin="0,8,0,0"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="易碎程度:" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <ComboBox Grid.Row="3" Grid.Column="1" Name="FragilityCombo" SelectedIndex="1" Width="150" HorizontalAlignment="Left" Margin="0,8,0,0">
                                <ComboBoxItem Content="很结实"/>
                                <ComboBoxItem Content="一般"/>
                                <ComboBoxItem Content="比较脆弱"/>
                                <ComboBoxItem Content="非常脆弱"/>
                            </ComboBox>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="用途:" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <ComboBox Grid.Row="4" Grid.Column="1" Name="UsageCombo" SelectedIndex="0" Width="150" HorizontalAlignment="Left" Margin="0,8,0,0">
                                <ComboBoxItem Content="电商发货"/>
                                <ComboBoxItem Content="零售货架"/>
                                <ComboBoxItem Content="送礼/高端"/>
                                <ComboBoxItem Content="食品餐饮"/>
                                <ComboBoxItem Content="工业/五金"/>
                            </ComboBox>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="数量:" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBox Grid.Row="5" Grid.Column="1" Name="QuantityBox" Text="500" Width="100" HorizontalAlignment="Left" Margin="0,8,0,0"/>

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="预算上限/个:" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBox Grid.Row="6" Grid.Column="1" Name="BudgetBox" Watermark="选填" Width="100" HorizontalAlignment="Left" Margin="0,8,0,0"/>

                            <Button Grid.Row="7" Grid.Column="1" Content="帮我找最优方案" Width="180" Height="38" Margin="0,12,0,0" HorizontalAlignment="Left" Click="OnRecommendClick"/>
                        </Grid>

                        <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Padding="10" Background="#F8F8F8" Margin="0,5,0,0">
                            <TextBlock Name="RecommendResultText" Text="等待输入..." TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab2: 盒型设计 -->
            <TabItem Header="盒型设计">
                <ScrollViewer>
                    <StackPanel Margin="15" Spacing="12">
                        <TextBlock Text="盒型参数" FontSize="16" FontWeight="SemiBold"/>

                        <StackPanel Spacing="8">
                            <TextBlock Text="盒型类型:" FontWeight="SemiBold"/>
                            <ComboBox Name="BoxTypeComboBox" SelectedIndex="0" Width="250" HorizontalAlignment="Left">
                                <ComboBoxItem Content="插舌式盒 (TuckEnd)"/>
                                <ComboBoxItem Content="邮寄盒 (Mailer)"/>
                                <ComboBoxItem Content="瓦楞标准开槽箱 (CorrugatedRSC)"/>
                                <ComboBoxItem Content="自动锁底盒 (AutoLockBottom)"/>
                                <ComboBoxItem Content="枕头盒 (PillowBox)"/>
                                <ComboBoxItem Content="天地盖精装盒 (RigidBox)"/>
                            </ComboBox>
                        </StackPanel>

                        <Grid ColumnDefinitions="*,*,*" Margin="0,5,0,0">
                            <StackPanel Grid.Column="0" Margin="0,0,7,0">
                                <TextBlock Text="长度 (mm):" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox Name="LengthTextBox" Text="150" Watermark="长度"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="7,0,7,0">
                                <TextBlock Text="宽度 (mm):" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox Name="WidthTextBox" Text="100" Watermark="宽度"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="7,0,0,0">
                                <TextBlock Text="高度 (mm):" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox Name="HeightTextBox" Text="80" Watermark="高度"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel>
                            <TextBlock Text="壁厚 (mm):" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox Name="WallThicknessTextBox" Text="2.5" Width="150" HorizontalAlignment="Left"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
                            <Button Name="Preview3DButton" Content="3D预览" Width="120" Height="38" Click="OnPreview3DClick"/>
                            <Button Content="结构验证" Width="120" Height="38" Click="OnValidateClick"/>
                        </StackPanel>

                        <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Padding="10" Background="#F8F8F8">
                            <TextBlock Name="DesignStatusText" Text="就绪" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab3: 材料与成本 -->
            <TabItem Header="材料与成本">
                <ScrollViewer>
                    <StackPanel Margin="15" Spacing="12">
                        <TextBlock Text="材料选择与成本估算" FontSize="16" FontWeight="SemiBold"/>

                        <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto,Auto" Margin="0,5,0,0">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="产品重量 (kg):" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Name="CostWeightBox" Text="2.5" Width="100" HorizontalAlignment="Left"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="订单数量:" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Name="CostQuantityBox" Text="1000" Width="100" HorizontalAlignment="Left" Margin="0,8,0,0"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="印刷工艺:" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <ComboBox Grid.Row="2" Grid.Column="1" Name="PrintMethodCombo" SelectedIndex="1" Width="150" HorizontalAlignment="Left" Margin="0,8,0,0">
                                <ComboBoxItem Content="无印刷"/>
                                <ComboBoxItem Content="柔印"/>
                                <ComboBoxItem Content="胶印"/>
                                <ComboBoxItem Content="数码印刷"/>
                            </ComboBox>

                            <Button Grid.Row="3" Grid.Column="1" Content="计算成本" Width="120" Height="38" Margin="0,12,0,0" HorizontalAlignment="Left" Click="OnCalculateCostClick"/>
                        </Grid>

                        <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Padding="10" Background="#F8F8F8">
                            <TextBlock Name="CostResultText" Text="等待计算..." TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab4: 物理验证 -->
            <TabItem Header="物理验证">
                <ScrollViewer>
                    <StackPanel Margin="15" Spacing="12">
                        <TextBlock Text="结构力学与缓冲保护" FontSize="16" FontWeight="SemiBold"/>

                        <Button Content="运行物理验证" Width="160" Height="38" HorizontalAlignment="Left" Click="OnPhysicsCheckClick"/>

                        <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Padding="10" Background="#F8F8F8">
                            <TextBlock Name="PhysicsResultText" Text="等待验证..." TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab5: 导出中心 -->
            <TabItem Header="导出中心">
                <ScrollViewer>
                    <StackPanel Margin="15" Spacing="12">
                        <TextBlock Text="导出文件" FontSize="16" FontWeight="SemiBold"/>

                        <WrapPanel Orientation="Horizontal">
                            <Button Content="导出PDF刀版" Width="140" Height="38" Margin="0,0,10,10" Click="OnExportPdfClick"/>
                            <Button Content="导出SVG" Width="120" Height="38" Margin="0,0,10,10" Click="OnExportSvgClick"/>
                            <Button Content="导出DXF" Width="120" Height="38" Margin="0,0,10,10" Click="OnExportDxfClick"/>
                            <Button Content="导出STL" Width="120" Height="38" Margin="0,0,10,10" Click="OnExportStlClick"/>
                            <Button Content="导出所有盒型" Width="140" Height="38" Margin="0,0,10,10" Click="OnExportAllClick"/>
                        </WrapPanel>

                        <TextBlock Text="3D打印导出" FontSize="14" FontWeight="SemiBold" Margin="0,10,0,0"/>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <ComboBox Name="Print3DTechCombo" SelectedIndex="0" Width="120">
                                <ComboBoxItem Content="FDM"/>
                                <ComboBoxItem Content="SLA"/>
                                <ComboBoxItem Content="SLS"/>
                                <ComboBoxItem Content="MJF"/>
                            </ComboBox>
                            <Button Content="检查打印适配" Width="140" Height="38" Click="OnCheck3DPrintClick"/>
                        </StackPanel>

                        <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Padding="10" Background="#F8F8F8">
                            <TextBlock Name="ExportStatusText" Text="就绪" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab6: 环保评分 -->
            <TabItem Header="环保评分">
                <ScrollViewer>
                    <StackPanel Margin="15" Spacing="12">
                        <TextBlock Text="环保合规与碳足迹" FontSize="16" FontWeight="SemiBold"/>

                        <Button Content="计算环保评分" Width="160" Height="38" HorizontalAlignment="Left" Click="OnSustainabilityClick"/>

                        <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Padding="10" Background="#F8F8F8">
                            <TextBlock Name="SustainabilityText" Text="等待计算..." TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- 底部信息 -->
        <TextBlock Grid.Row="2" Text="PicoGK 1.7.7.4 + PdfSharp 6.2.0 + Avalonia 11.2.2"
                   FontSize="11" Foreground="Gray" Margin="0,0,0,8" HorizontalAlignment="Center"/>
    </Grid>

</Window>
